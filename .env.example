# Copy to .env and fill in. .env is gitignored and must never be committed.

# Anthropic / Claude API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Model used by the agents
SHERLOG_MODEL=claude-sonnet-4-6

# Postgres + pgvector connection (matches docker-compose.yml)
DATABASE_URL=postgresql://sherlog:sherlog@localhost:5432/sherlog

# Max self-correction iterations before Sherlog gives up and reports anyway
SHERLOG_MAX_ITERATIONS=3
